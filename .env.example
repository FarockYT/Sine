VITE_AI_PROVIDER=local
VITE_AI_MODEL=local-planner
VITE_AI_ENDPOINT=
VITE_APP_NAME=Sine Inverse
VITE_CLOUD_SYNC_ENDPOINT=/api/cloud-sync

# Optional: choose blob, redis, or auto. Auto prefers Redis/KV when available.
SINE_SYNC_BACKEND=auto

# Cloud sync prefers Vercel Blob on Vercel.
# When a Blob store is connected to the Vercel project, Vercel provides BLOB_STORE_ID
# and an OIDC token to serverless functions. For local/off-Vercel testing, use
# BLOB_READ_WRITE_TOKEN instead.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Only needed if you add Blob webhooks later. Sine Inverse sync does not use it.
BLOB_WEBHOOK_PUBLIC_KEY=

# Fallback cloud sync for Vercel/Upstash Redis REST.
# Vercel KV usually provides KV_REST_API_URL and KV_REST_API_TOKEN automatically.
SINE_SYNC_REST_URL=
SINE_SYNC_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional for read-only tooling. Sine Inverse save/load needs the write token above.
KV_REST_API_READ_ONLY_TOKEN=
